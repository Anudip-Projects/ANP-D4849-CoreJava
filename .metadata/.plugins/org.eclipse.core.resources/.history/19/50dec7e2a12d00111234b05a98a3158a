package com.anudip.inheri.hasA;


//IS-A Relationship
public class Employee extends Person{
	int eid;
	int sid;

	//HAS-A Relataion or Composition
	Address addrs;
	@Override
	public String toString() {
		return "Employee [eid=" + eid + "]";
	}

	public Employee(String name, int age, int eid) {
		super(name, age);
		this.eid = eid;
	}

	public int getEid() {
		return eid;
	}

	public void setEid(int eid) {
		this.eid = eid;
	}

}
