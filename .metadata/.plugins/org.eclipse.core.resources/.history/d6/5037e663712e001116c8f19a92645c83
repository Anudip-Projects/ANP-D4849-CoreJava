package com.anudip.arrayaa;

public class Test02_copyARray {

	public static void main(String[] args) {
		
		int arr1[] = {10, 20, 30};
		
		int arr2[] = new int[arr1.length];
		
		for(int i = 0; i<arr1.length-1 ; i++) {
			
			arr2[i] =  arr1[i];
		}
		
		for(int i : arr2) {
			System.out.println(i);
		}
	}
}
