package com.anudip.arrayaa;

import java.util.Scanner;

public class Test01_ArrayIntilizataion {

	public static void main(String[] args) {

		//array declaration
		int arr[];

		//static array
		int arr1[] = {1,2,3};  //array size-> 3
		int length = arr1.length;
		System.out.println("lenth or size of array ::" +length);		
		System.out.println(arr1[2]);

		//retriving the array
		//travesing the array
		//traversing the array  using for loop
		for(int i = 0 ; i< arr1.length ; i++) {
			System.out.println("array value ::" +arr1[i]);
		}

		int arr3[] = new int[4];  //size of array
		System.out.println(arr3[2]);

		Scanner sc = new Scanner(System.in);
		System.out.println("enetr value ");
		int val = sc.nextInt();
		arr3[0]  = val;

		System.out.println(arr3[0]);
		//Using for ach loop
	}
}
