package com.anudip.collection;

import java.util.ArrayList;

public class Test01_AL {

	public static void main(String[] args) {		

		ArrayList<Student> al = new ArrayList<Student>();

		Student s1 = new Student(1, "Raja", 5000);
		Student s2 = new Student(2, "Rajesh", 5000);
		Student s3 = new Student(3, "Rama", 5000);
		Student s4 = new Student(4, "Rani", 5000);
		Student s5 = new Student(5, "om", 5000);

		al.add(s1);
		al.add(s2);
		al.add(s3);
		al.add(s4);
		al.add(s5);

		System.out.println(al);

		System.out.println(al.size());//5

		//update the fee by 1k

		//id = 1 and 5
		for(int i = 0; i<=al.size()-1; i++) {//0 1 2 3 4
		
			Student obj = al.get(i);
			if(obj.getId() == 1  ||  obj.getId() == 5 ) {
				obj.setCourseFees(6000);					
			}

			System.out.println(al.get(i));
		}

		System.out.println(al);

	}
}
