public class Test01 {


	public static void main(String[] args) {

		//Unary Operator ++   --
		//increment op
		//preIncre ++and postIncre
		
		int a = 10;
		System.out.println(a);
		++a;  //1 + 10 => 11
		System.out.println("preINcre:: " +a);  //11
		a++;  //11+1 => 12
		System.out.println("postINcre::" +a);
		
		int p = 100;
		//System.out.println(++p);  //1 + 100 => 101
		System.out.println(p++);  //1 + 100 => 101
		System.out.println(p);
		
		
		//decrement
				//predecre and postdecre
	}
}
